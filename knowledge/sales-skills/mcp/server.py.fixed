                    "type": "array",
                    "items": {"type": "string"},
                    "description": "历史对话上下文（可选，用于多轮需求演化分析）"
                }
            },
            "required": ["message"]
        }
    },
    {
        "name": "objection_handler",
        "description": "异议处理话术生成器。内置价格/信任/拖延/对比/可信度/范围6大类异议场景，每个场景3层级话术(light/medium/heavy)。返回结构化话术含tone、script、适用场景说明。",
        "inputSchema": {
            "type": "object",
            "properties": {
                "category": {
                    "type": "string",
                    "enum": ["price", "trust", "delay", "compare", "credibility", "scope"],
                    "description": "异议类型分类"
                },
                "scenario": {
                    "type": "string",
                    "description": "具体场景关键词（用于精确匹配）"
                },
                "tier": {
                    "type": "string",
                    "enum": ["light", "medium", "heavy"],
                    "default": "medium",
                    "description": "话术层级: light=轻量回应, medium=标准话术, heavy=深入处理"
                },
                "list_all": {
                    "type": "boolean",
                    "default": False,
                    "description": "如为true，列出所有异议场景而非生成话术"
                }
            }
        }
    },
    {
        "name": "private_sop_runner",
        "description": "私域SOP执行器。管理Day-0至Day-7客户跟进全流程，含触达时机、话术模板、合规规则、渠道优先级矩阵。支持生成某日SOP、模拟7天旅程、查询客户日程。",
        "inputSchema": {
            "type": "object",
            "properties": {
                "action": {
                    "type": "string",
                    "enum": ["day-sequence", "customer-journey", "get-schedule"],
                    "description": "操作类型"
                },
                "day": {
                    "type": "integer",
                    "description": "目标天数(Day-0到Day-7)"
                },
                "grade": {
                    "type": "string",
                    "enum": ["A", "B", "C", "D"],
                    "description": "客户分级"
                },
                "channel": {
                    "type": "string",
                    "enum": ["wechat", "moments", "call", "email"],
                    "description": "触达渠道"
                },
                "scenario": {
                    "type": "string",
                    "description": "客户场景（customer-journey使用）"
                },
                "sid": {
                    "type": "string",
                    "description": "会话ID（get-schedule使用）"
                }
            },
            "required": ["action"]
        }
    },
    {
        "name": "compliance_rewrite",
            "description": "违规内容自动改写引擎。对含违规词的销售话术/文案执行自动合规修复，返回改写前后对比、改动说明、二次验证结果。支持指定目标规则ID精准修复。",
            "inputSchema": {
                "type": "object",
                "properties": {
                    "text": {"type": "string", "description": "待改写的原文本"},
                    "target_rules": {"type": "array", "items": {"type": "string"}, "description": "目标规则ID列表(空=自动检测所有违规)"}
                },
                "required": ["text"]
            }
        },
        {
            "name": "lifecycle_analyzer",
            "description": "客户生命周期分析引擎。D0→D30全阶段旅程管理，含认知/信任/方案/决策/转化5阶段模型。支持现状分析、优化策略推荐、内容方向建议。",
            "inputSchema": {
                "type": "object",
                "properties": {
                    "action": {"type": "string", "enum": ["analyze", "get_stages", "optimize"]},
                    "last_touch_day": {"type": "integer", "description": "上次触达距今天数"},
                    "customer_grade": {"type": "string", "enum": ["A", "B", "C", "D"]},
                    "engagement_score": {"type": "number", "description": "互动评分(0-1)"}
                },
                "required": ["action"]
            }
        },
        {
            "name": "client_crm_tag",
            "description": "CRM标签同步与分级管理。为会话客户生成多维度标签(risk_profile/purchase_intent/compliance_flag/lifecycle_stage)，支持查询、导出。",
            "inputSchema": {
                "type": "object",
                "properties": {
                    "action": {"type": "string", "enum": ["generate", "query", "export_all", "categorize_tags"]},
                    "session_id": {"type": "string", "description": "会话ID"},
                    "customer_grade": {"type": "string", "enum": ["A", "B", "C", "D"]},
                    "needs_detected": {"type": "array", "items": {"type": "string"}},
                    "engagement_score": {"type": "number"},
                    "compliance_status": {"type": "string", "enum": ["PASS", "FLAGGED", "BLOCKED"]}
                },
                "required": ["action"]
            }
        },
        {
            "name": "multi_turn_dialogue",
            "description": "多轮对话上下文管理器。在stdio模式下管理会话级状态追踪(80轮窗口)，支持创建/添加轮次/获取上下文/生成摘要/删除会话。",
            "inputSchema": {
                "type": "object",
                "properties": {
                    "action": {"type": "string", "enum": ["create", "add_turn", "get_context", "summarize", "list_sessions", "delete"]},
                    "session_id": {"type": "string"},
                    "content": {"type": "string"},
                    "grade": {"type": "string", "enum": ["A", "B", "C", "D"]}
                },
                "required": ["action"]
            }
        },
        {
            "name": "compliance_trend_analysis",
            "description": "合规趋势分析引擎。分析历史合规检查记录，发现高频违规词/模式，评估风险等级，生成改进建议。支持单条记录、规则统计查询。",
            "inputSchema": {
                "type": "object",
                "properties": {
                    "action": {"type": "string", "enum": ["analyze", "record", "get_rule_stats"]},
                    "session_id": {"type": "string"},
                    "status": {"type": "string", "enum": ["PASS", "FLAGGED", "BLOCKED"]}
                },
                "required": ["action"]
            }
        }
    ]


# ============================================================
# MCP Server Core (stdio-based JSON-RPC)
# ============================================================

def build_tools_list():
    """构建MCP tools列表响应 (v2.0 - 10 tools)"""
    return {"tools": MCP_TOOLS}


def handle_insurance_product_query(params: dict) -> dict:
    """Tool 1: 产品条款查询"""
    action = params.get("action")
    products = load_product_db()

    if action == "list":
        output = {
            "products_compared": len(products),
            "products": [
                {"id": p["id"], "name_cn": p["name_cn"], "insurance_type": p["insurance_type"],
                 "category": p["category"], "coverage_summary": p["coverage_summary"][:100] + "..."}
                for p in products
            ],
            "usage_hint": "使用 detail action + product_name 查询详情"
        }
    elif action == "detail":
        product = _fuzzy_match_product(params.get("product_name", ""), products)
        if not product:
            return {"error": "product_not_found", "available_products": [p["name_cn"] for p in products]}
        output = {
            "id": product["id"], "name_cn": product["name_cn"],
            "insurance_type": product["insurance_type"], "category": product["category"],
            "coverage_summary": product["coverage_summary"],
            "detailed_coverage": product.get("detailed_coverage", "详见条款说明"),
            "exclusions": product["exclusions"],
            "suitable_for": product["suitable_for"],
            "compliance_points": product.get("compliance_points", ["依合同约定给付保险金", "不得承诺收益"]),
            "common_questions": [q for q in product.get("common_questions", [])],
            "regulatory_refs": product.get("regulatory_refs", []),
        }
    else:
        output = {"error": "invalid_action", "available_actions": ["list", "detail"]}

    return {"result": output}


def handle_compliance_check(params: dict) -> dict:
    """Tool 2: 合规检测"""
    text = params.get("text", "")
    strict_mode = params.get("strict_mode", False)

    violations = []

    # 红线扫描
    for rule in RED_LINE_RULES:
        matches = re.findall(rule["pattern"], text, re.IGNORECASE)
        if matches:
            violations.append({
                "rule_id": rule["rule_id"],
                "name": rule["name"],
                "severity": rule["severity"],
                "matched_text": matches[0],
                "suggestion": rule["suggestion"],
                "regulatory_ref": REGULATORY_REFS.get(rule["rule_id"], "")
            })

    # 黄线扫描
    for rule in YELLOW_LINE_RULES:
        matches = re.findall(rule["pattern"], text, re.IGNORECASE)
        if matches:
            violations.append({
                "rule_id": rule["rule_id"],
                "name": rule["name"],
                "severity": "MEDIUM",
                "matched_text": matches[0],
                "suggestion": rule["suggestion"],
                "regulatory_ref": REGULATORY_REFS.get(rule["rule_id"], "")
            })

    # 严格模式额外规则
    if strict_mode:
        hidden_patterns = [
            ("RL-011", "隐式收益暗示", r"(投资回报|资产增值|财富增值)", "MEDIUM", "改为'财务规划工具'"),
        ]
        for rid, name, pat, sev, sug in hidden_patterns:
            if re.search(pat, text):
                violations.append({
                    "rule_id": rid, "name": name, "severity": sev,
                    "matched_text": f"[严格模式触发]",
                    "suggestion": sug
                })

    # 状态判定
    has_critical = any(v["severity"] == "CRITICAL" for v in violations)
    has_high = any(v["severity"] == "HIGH" for v in violations)

    if has_critical:
        status = ComplianceStatus.BLOCKED.value
    elif has_high:
        status = ComplianceStatus.FLAGGED.value
    else:
        status = ComplianceStatus.PASS.value

    return {
        "result": {
            "compliance_status": status,
            "violations_found": len(violations),
            "violation_details": violations,
            "red_line_count": len([v for v in violations if v["severity"] == "CRITICAL"]),
            "yellow_line_count": len([v for v in violations if v["severity"] == "MEDIUM"]),
            "rule_coverage": {"red_lines": len(RED_LINE_RULES), "yellow_lines": len(YELLOW_LINE_RULES)},
        }
    }


def handle_needs_assessment(params: dict) -> dict:
    """Tool 3: 客户需求诊断"""
    message = params.get("message", "")
    context_history = params.get("context_history", [])
    
    signals = {}
    lower_msg = message.lower()

    # 结合历史对话上下文（多轮需求演化）
    for hist in context_history:
        lower_msg += " " + hist.lower()

    for need_type, keywords in NEED_KEYWORDS.items():
        matched = [kw for kw in keywords if kw in lower_msg]
        if matched:
            confidence = min(0.9, 0.5 + 0.2 * len(matched))
            signals[need_type] = {"need_type": need_type, "confidence": round(confidence, 2), "keywords_matched": matched}

    # 排序取Top-3
    sorted_signals = sorted(signals.values(), key=lambda x: x["confidence"], reverse=True)[:3]

    # 客户分级（增强版：更精准的关键词映射）
    need_types = {s["need_type"] for s in sorted_signals}
    
    # 检测额外隐含信号
    lower_msg = message.lower()
    if not signals.get("health_concern"):
        health_keywords = ["结节", "囊肿", "血压高", "血糖高", "脂肪肝", "尿酸", "息肉", "炎症"]
        for kw in health_keywords:
            if kw in lower_msg:
                signals["health_concern"] = {"need_type": "health_concern", "confidence": 0.5, "keywords_matched": [kw]}
                sorted_signals = sorted(signals.values(), key=lambda x: x["confidence"], reverse=True)[:3]
                need_types.add("health_concern")
    
    if not signals.get("medical_need"):
        medical_keywords = ["体检", "验血", "抽血", "挂号", "医生", "门诊", "住院"]
        for kw in medical_keywords:
            if kw in lower_msg:
                signals["medical_need"] = {"need_type": "medical_need", "confidence": 0.45, "keywords_matched": [kw]}
    
    need_types = {s["need_type"] for s in sorted_signals}  # recompute
    
    # 默认分级
    grade = CustomerGrade.D.value
    
    # 分级逻辑（修正版）
    health_related = bool(need_types & {"health_concern", "medical_need"})
    income_family = bool(need_types & {"income_protection", "family_responsibility"})
    cross_border_flag = bool(need_types & {"cross_border"}) or any(kw in lower_msg for kw in ["内地","跨境","大湾区","海归"])
    
    if health_related and income_family:
        grade = CustomerGrade.A.value
    elif (health_related and len(sorted_signals) >= 2) or cross_border_flag:
        grade = CustomerGrade.A.value
    elif income_family or health_related:
        grade = CustomerGrade.B.value
    elif "travel_fear" in need_types or "savings_plan" in need_types:
        grade = CustomerGrade.C.value
    else:
        grade = CustomerGrade.D.value

    # 紧迫度
    urgent_kw = ["马上", "着急", "最近", "刚发现", "担心", "焦虑", "怎么办"]
    warm_kw = ["考虑", "想咨询", "打算", "了解", "计划"]
    if any(kw in lower_msg for kw in urgent_kw):
        urgency = Urgency.URGENT.value
    elif any(kw in lower_msg for kw in warm_kw):
        urgency = Urgency.WARM.value
    else:
        urgency = Urgency.COLD.value

    need_names = {
        "health_concern": "健康风险", "medical_need": "医疗保障",
        "income_protection": "收入保护", "family_responsibility": "家庭责任",
        "travel_fear": "跨境/境外医疗", "savings_plan": "储蓄养老规划",
        "property_risk": "财产保障", "cross_border": "跨境保险需求",
        "elderly_care": "老年保障"
    }

    product_recommendation = None
    if grade in ['A', 'B']:
        primary = sorted_signals[0]["need_type"] if sorted_signals else ""
        PRODUCT_MAP = {
            "health_concern": {"core": "重疾险", "compliant_desc": "确诊合同约定的疾病后,一次性给付保险金"},
            "medical_need": {"core": "医疗险", "compliant_desc": "补充社保报销范围之外的高额医疗费用"},
            "income_protection": {"core": "定期寿险", "compliant_desc": "保障期内因身故/全残给付保险金"},
            "family_responsibility": {"core": "定期寿险+重疾险组合", "compliant_desc": "构建家庭财务安全网"},
            "travel_fear": {"core": "全球医疗险", "compliant_desc": "覆盖全球医疗机构的医疗费用"},
            "savings_plan": {"core": "年金险", "compliant_desc": "通过长期储蓄型产品锁定确定性"},
            "cross_border": {"core": "全球医疗险", "compliant_desc": "跨境身份人群的保障规划"},
        }
        prod = PRODUCT_MAP.get(primary, {})
        product_recommendation = {
            "core_product": prod.get("core", "待定"),
            "action": "consultation_booking" if grade in ['A', 'B'] else "content_nurture"
        }

    return {
        "result": {
            "detected_needs": sorted_signals,
            "customer_grade": grade,
            "urgency": urgency,
            "product_recommendation": product_recommendation,
            "needs_summary": f"检测到{len(sorted_signals)}个风险信号: {', '.join(need_names.get(s['need_type'], s['need_type']) for s in sorted_signals) if sorted_signals else '无明确信号'}",
            "context_enhanced": len(context_history) > 0,
            "context_turns_considered": len(context_history),
        }
    }


def handle_objection_handler(params: dict) -> dict:
    """Tool 4: 异议处理话术生成"""
    scripts = load_objection_db()

    if not scripts:
        return {"error": "objection_db_not_found"}

    action_list = params.get("list_all", False)
    
    if action_list:
        by_cat = {}
        for s in scripts:
            cat = s["category"]
            by_cat.setdefault(cat, []).append({"scenario": s["scenario"], "scenario_cn": s["scenario_cn"]})
        return {
            "result": {
                "action": "list_all_scenarios",
                "total_scenarios": len(scripts),
                "categories": by_cat,
                "tier_options": ["light", "medium", "heavy"]
            }
        }

    category = params.get("category")
    scenario = params.get("scenario", "")
    tier = params.get("tier", "medium")

    matched = _fuzzy_match_objection(category, scenario, scripts)
    
    if not matched:
        return {
            "error": "no_matching_scenario",
            "suggestion": f"请提供准确的异议类型或场景关键词",
            "available_categories": list({s["category"] for s in scripts})
        }

    tier_data = None
    for t in matched.get("tier_levels", []):
        if t["level"] == tier:
            tier_data = t
            break
    if not tier_data and matched.get("tier_levels"):
        tier_data = matched["tier_levels"][0]

    return {
        "result": {
            "category": matched["category"],
            "scenario_en": matched.get("scenario", ""),
            "scenario_cn": matched.get("scenario_cn", ""),
            "tier_requested": tier,
            "tone": tier_data.get("tone", "professional") if tier_data else "unknown",
            "script": tier_data.get("script", "") if tier_data else "",
            "full_tier_options": [{"level": t["level"], "tone": t["tone"], "script": t["script"]}
                                  for t in matched.get("tier_levels", [])]
        }
    }


def handle_private_sop_runner(params: dict) -> dict:
    """Tool 5: 私域SOP执行器"""
    action = params.get("action")

    if action == "day-sequence":
        day_num = int(params.get("day", 3))
        key = f"Day-{min(day_num, 7)}"
        grade = params.get("grade", "B")
        channel = params.get("channel", "wechat")

        seq = DAY_SEQUENCES.get(key)
        if not seq:
            return {"error": "invalid_day", "available_days": list(DAY_SEQUENCES.keys())}
        
        if channel not in seq["channels"]:
            return {
                "error": "channel_not_available_for_day",
                "requested_channel": channel,
                "available_channels": seq["channels"]
            }

        return {
            "result": {
                "day": key, "timing": seq["timing"], "action": seq["action"],
                "channel": channel, "compliance_level": seq["compliance_level"],
                "recommended_scripts": seq["scripts"], "rules": seq["rules"],
                "grade_hint": f"Grade {grade}客户适用" if grade in ['A','B'] else "纯科普引导"
            }
        }

    elif action == "customer-journey":
        grade = params.get("grade", "A")
        scenario = params.get("scenario")
        
        journey = []
        for d in range(8):
            dn = min(d, 7)
            key = f"Day-{dn}" if dn < 7 else "Day-7-final"
            action_type = ["welcome_add","content_nurture","needs_discovery","solution_or_cta","final_followup"][min(d//2, 4)]
            journey.append({"day": f"D{d}", "action": action_type, "compliance_level": DAY_SEQUENCES.get(key,{}).get("compliance_level")})

        result = {
            "simulation": "7-day_journey", "customer_grade": grade,
            "total_touchpoints": 8, "journey": journey,
            "compliance_warnings": [
                "D0-D1: 不得提及具体产品/收益", "D3: 必须声明'非销售'",
                "D5+: B级以上才可用方案框架话术", "D7: CTA最多3次，之后静默"
            ]
        }
        if scenario:
            result["scenario"] = scenario
        return {"result": result}

    elif action == "get-schedule":
        sid = params.get("sid")
        if not sid:
            return {"error": "session_id_required"}
        
        schedule = []
        for dn in range(8):
            key = f"Day-{min(dn,7)}"
            schedule.append({
                "day": key,
                "action": DAY_SEQUENCES.get(key,{}).get("action","final_followup"),
                "compliance_level": DAY_SEQUENCES.get(key,{}).get("compliance_level","high_risk")
            })

        return {
            "result": {
                "session_id": sid,
                "schedule": schedule,
                "channel_priority_matrix": CHANNEL_PRIORITY,
                "next_action_required": schedule[0]
            }
        }

    return {"error": "invalid_action", "available_actions": ["day-sequence", "customer-journey", "get-schedule"]}


