def handle_initialize() -> dict:
    return {
        "protocolVersion": "2024-11-05",
        "capabilities": {"tools": {"listChanged": True}},
        "serverInfo": {"name": "insurance-sales-mcp", "version": "1.1.0"},
    }


def handle_tools_list() -> dict:
    return build_tools_list()


# ============================================================
# R30 v2.0: 新增工具 6 - compliance_rewrite (违规内容自动改写)
# ============================================================

def handle_compliance_rewrite(params: dict) -> dict:
    """Tool 6: 合规改写引擎。
    输入：原文本 + 可选的目标规则ID
    输出：改写后的合规文本 + 改动说明 + 原始违规引用
    """
    text = params.get("text", "")
    target_rules = params.get("target_rules", [])  # 空=自动检测所有违规
    
    if not text:
        return {"error": "text_required"}
    
    # Step 1: 先做合规检测找出违规
    violations = []
    for rule in RED_LINE_RULES + YELLOW_LINE_RULES:
        matches = re.findall(rule["pattern"], text, re.IGNORECASE)
        if matches:
            rule_id = rule["rule_id"]
            if target_rules and rule_id not in target_rules:
                continue
            violations.append({
                "rule_id": rule_id,
                "severity": rule["severity"],
                "matched_text": matches[0],
                "suggestion": rule["suggestion"]
            })
    
    if not violations:
        return {"result": {"status": "no_violations", "original_text": text, "rewrite_applied": False, "changes": []}}
    
    # Step 2: 自动改写
    rewritten = text
    changes = []
    for v in violations:
        rule_id = v["rule_id"]
        rewrite_info = COMPLIANCE_REWRITE_DB.get(rule_id)
        if rewrite_info:
            for bad_pattern in rewrite_info["bad"]:
                new_texts = [r for r in rewrite_info["good"] if re.search(bad_pattern, rewritten, re.IGNORECASE)]
                if new_texts:
                    old_match = re.search(bad_pattern, rewritten, re.IGNORECASE)
                    if old_match:
                        replacement = new_texts[0]
                        rewritten = re.sub(bad_pattern, replacement, rewritten, count=1, flags=re.IGNORECASE)
                        changes.append({
                            "rule_id": rule_id,
                            "original": old_match.group(0),
                            "rewritten": replacement,
                            "action": "auto_rewritten"
                        })
    
    # Step 3: 二次合规验证
    re_violations = []
    for rule in RED_LINE_RULES + YELLOW_LINE_RULES:
        if re.findall(rule["pattern"], rewritten, re.IGNORECASE):
            re_violations.append(rule["rule_id"])
    
    status = "fully_compliant" if not re_violations else "partial_rewrite_needed"
    
    return {
        "result": {
            "status": status,
            "original_text": text,
            "rewritten_text": rewritten,
            "changes_applied": changes,
            "changes_count": len(changes),
            "remaining_violations": re_violations if re_violations else None,
            "requires_manual_review": status == "partial_rewrite_needed",
            "rewrite_confidence": 0.95 if not re_violations else 0.7
        }
    }


# ============================================================
# R30 v2.0: 新增工具 7 - lifecycle_analyzer (客户生命周期分析)
# ============================================================

LIFECYCLE_STAGES = {
    "D0_D1": {"name": "认知阶段", "duration": "0-2天", "goal": "建立信任+品牌认知", "content_type": ["科普内容", "行业解读", "政策解读"], "compliance_level": "LOW", "kpi": ["阅读率>60%", "收藏率>5%"]},
    "D2_D4": {"name": "信任阶段", "duration": "3-5天", "goal": "需求挖掘+专业度展示", "content_type": ["案例分享(脱敏)", "保险制度解析", "QA互动"], "compliance_level": "LOW-MED", "kpi": ["互动率>10%", "私信转化率>3%"]},
    "D5_D7": {"name": "方案阶段", "duration": "6-8天", "goal": "方案框架展示+初步匹配", "content_type": ["保障框架对比(无产品名)", "GN16解读", "需求测评工具"], "compliance_level": "MED", "kpi": ["CTA点击率>8%", "预约咨询>2%"]},
    "D8_D14": {"name": "决策阶段", "duration": "9-15天", "goal": "深度沟通+异议处理", "content_type": ["1v1需求梳理", "方案对比框架", "客户见证(脱敏)"], "compliance_level": "MED-HIGH", "kpi": ["预约率>15%", "咨询转化率>30%"]},
    "D15_D30": {"name": "转化/维护阶段", "duration": "16-30天", "goal": "促成+关系维护", "content_type": ["保单检视", "理赔案例(脱敏)", "周年回访"], "compliance_level": "HIGH", "kpi": ["转化率>20%", "转介绍率>5%"]}
}

def handle_lifecycle_analyzer(params: dict) -> dict:
    """Tool 7: 客户生命周期分析引擎。
    分析客户当前所处阶段，推荐优化策略和内容方向。
    """
    action = params.get("action", "analyze")
    
    if action == "analyze":
        # Input: customer signals
        last_touch_day = int(params.get("last_touch_day", 0))
        customer_grade = params.get("customer_grade", "D")
        engagement_score = float(params.get("engagement_score", 0.3))
        content_engaged = params.get("content_engaged", ["policy_update"])
        
        # Determine current stage
        if last_touch_day <= 1:
            stage = "D0_D1"
        elif last_touch_day <= 4:
            stage = "D2_D4"
        elif last_touch_day <= 7:
            stage = "D5_D7"
        elif last_touch_day <= 14:
            stage = "D8_D14"
        else:
            stage = "D15_D30"
        
        # Engagement-based recommendations
        if engagement_score < 0.3:
            content_strategy = "content_nurture_heavy"  # 重度培育
        elif engagement_score < 0.6:
            content_strategy = "content_nurture_light"  # 轻度培育
        else:
            content_strategy = "cta_push"  # CTA推进
        
        # Stage + grade based recommendation matrix
        rec_matrix = {
            ("D0_D1", "A"): {"priority": "high", "next_action": "rapid_transition_D2_D4"},
            ("D0_D1", "B"): {"priority": "medium", "next_action": "content_nurture"},
            ("D2_D4", "A"): {"priority": "high", "next_action": "needs_discovery_tool"},
            ("D5_D7", "A"): {"priority": "urgent", "next_action": "consultation_booking"},
            ("D8_D14", "A"): {"priority": "critical", "next_action": "proposal_preparation"},
        }
        rec = rec_matrix.get((stage, customer_grade), {"priority": "normal", "next_action": "standard_nurture"})
        
        return {
            "result": {
                "current_stage": stage,
                "stage_info": LIFECYCLE_STAGES[stage],
                "engagement_score": engagement_score,
                "content_strategy": content_strategy,
                "grade_lifecycle_rec": rec,
                "recommended_content_types": LIFECYCLE_STAGES[stage]["content_type"],
                "compliance_level": LIFECYCLE_STAGES[stage]["compliance_level"],
                "estimated_conversion_timeline_days": 7 + max(0, (int(params.get("last_touch_day", 0)) - 5)),
                "optimization_suggestions": [
                    f"当前处于{LIFECYCLE_STAGES[stage]['name']}阶段，建议重点提升互动质量",
                    f"Grade {customer_grade}客户在{stage}阶段的平均转化周期为7-14天",
                    f"推荐内容方向：{', '.join(LIFECYCLE_STAGES[stage]['content_type'])}",
                    "避免在D0-D1阶段提及产品具体收益"
                ]
            }
        }
    
    elif action == "get_stages":
        return {"result": {"lifecycle_stages": LIFECYCLE_STAGES, "total_stages": len(LIFECYCLE_STAGES)}}
    
    elif action == "optimize":
        # Full optimization pipeline
        grade = params.get("customer_grade", "C")
        stage = params.get("current_stage", "D2_D4")
        days_active = int(params.get("days_active", 3))
        touchpoint_count = int(params.get("touchpoint_count", 2))
        conversion_probability = float(params.get("conversion_probability", 0.15))
        
        suggestions = []
        if days_active < 7 and grade in ['A', 'B']:
            suggestions.append({"priority": "high", "action": "accelerate_to_D5", "reason": f"Grade {grade}客户应在D5前触发需求挖掘"})
        if touchpoint_count < 3:
            suggestions.append({"priority": "medium", "action": "increase_touchpoints", "reason": "接触点不足，建议补充content_nurture内容"})
        if conversion_probability > 0.3 and stage not in ["D8_D14", "D15_D30"]:
            suggestions.append({"priority": "critical", "action": "immediate_cta", "reason": f"转化率{conversion_probability*100:.0f}%已达决策门槛，立即触发CTA"})
        
        return {
            "result": {
                "optimization_pipeline": True,
                "current_state": {"grade": grade, "stage": stage, "days_active": days_active, "touchpoints": touchpoint_count},
                "recommendations": suggestions if suggestions else [{"priority": "normal", "action": "continue_standard_nurture", "reason": "当前节奏合理"}],
                "estimated_roi_days": 14 if grade in ["A"] else (21 if grade in ["B"] else 30)
            }
        }
    
    return {"error": "invalid_action", "available_actions": ["analyze", "get_stages", "optimize"]}


# ============================================================
# R30 v2.0: 新增工具 8 - client_crm_tag (CRM标签管理)
# ============================================================

CRM_TAG_CATEGORIES = {
    "risk_profile": {"labels": ["健康风险型", "收入保障型", "家庭责任型", "储蓄养老型", "跨境需求型", "境外医疗型"], "weight_source": "needs_assessment"},
    "purchase_intent": {"labels": ["高意向(ready)", "中意向(concerned)", "低意向(browsing)", "冷客户(cooled)"], "weight_source": "engagement_score"},
    "compliance_flag": {"labels": ["无风险(clean)", "黄线提醒(yellow_warned)", "红线阻断(red_blocked)", "敏感标签(sensitive)"], "weight_source": "compliance_check"},
    "lifecycle_stage": {"labels": list(LIFECYCLE_STAGES.keys()), "weight_source": "last_touch_day"},
    "communication_pref": {"labels": ["文字型(wechat)", "语音型(call)", "图文型(moments)", "不敏感(not_responsive)"], "weight_source": "interaction_history"},
}

DEMO_CRM_DB: Dict[str, dict] = {}

def handle_client_crm_tag(params: dict) -> dict:
    """Tool 8: CRM标签同步与分级管理。
    为给定客户/会话生成或更新CRM标签，支持查询、同步、导出。
    """
    action = params.get("action", "generate")
    session_id = params.get("session_id", params.get("sid", ""))
    
    if action == "generate":
        # Derive tags from needs/grade/compliance data
        grade = params.get("customer_grade", "D")
        needs = params.get("needs_detected", [])
        engagement = float(params.get("engagement_score", 0.1))
        compliance_status = params.get("compliance_status", "clean")
        last_touch = int(params.get("last_touch_day", 0))
        
        # Risk profile tag
        risk_tags = []
        need_map = {"health_concern": "健康风险型", "medical_need": "医疗保障型", "income_protection": "收入保障型",
                    "family_responsibility": "家庭责任型", "savings_plan": "储蓄养老型", "cross_border": "跨境需求型",
                    "travel_fear": "境外医疗型"}
        for n in needs:
            mapped = need_map.get(n, None)
            if mapped and mapped not in risk_tags:
                risk_tags.append(mapped)
        
        # Purchase intent
        if engagement >= 0.7:
            intent_tag = "高意向(ready)"
        elif engagement >= 0.4:
            intent_tag = "中意向(concerned)"
        elif engagement >= 0.15:
            intent_tag = "低意向(browsing)"
        else:
            intent_tag = "冷客户(cooled)"
        
        # Compliance
        comp_map = {"PASS": "无风险(clean)", "FLAGGED": "黄线提醒(yellow_warned)", "BLOCKED": "红线阻断(red_blocked)"}
        comp_tag = comp_map.get(compliance_status, "无风险(clean)")
        
        # Lifecycle
        if last_touch <= 1: lc_stage = "D0_D1"
        elif last_touch <= 4: lc_stage = "D2_D4"
        elif last_touch <= 7: lc_stage = "D5_D7"
        elif last_touch <= 14: lc_stage = "D8_D14"
        else: lc_stage = "D15_D30"
        
        tags = {
            "risk_profile": risk_tags if risk_tags else ["未分类"],
            "purchase_intent": intent_tag,
            "compliance_flag": comp_tag,
            "lifecycle_stage": lc_stage,
            "customer_grade": grade
        }
        
        if session_id:
            DEMO_CRM_DB[session_id] = tags
        
        return {"result": {"action": "tags_generated", "session_id": session_id, "tags": tags, "tag_categories": list(CRM_TAG_CATEGORIES.keys())}}
    
    elif action == "query":
        sid = params.get("session_id")
        if not sid:
            return {"error": "session_id_required"}
        tags = DEMO_CRM_DB.get(sid)
        if not tags:
            return {"result": {"message": f"No CRM tags found for session {sid}"}}
        return {"result": {"session_id": sid, "tags": tags}}
    
    elif action == "export_all":
        return {"result": {"total_customers": len(DEMO_CRM_DB), "customers": DEMO_CRM_DB}}
    
    elif action == "categorize_tags":
        return {"result": CRM_TAG_CATEGORIES}
    
    return {"error": "invalid_action", "available_actions": ["generate", "query", "export_all", "categorize_tags"]}


# ============================================================
# R30 v2.0: 新增工具 9 - multi_turn_dialogue (多轮对话管理)
# ============================================================

def handle_multi_turn_dialogue(params: dict) -> dict:
    """Tool 9: 多轮对话上下文管理器。
    在stdio模式下提供会话级状态追踪（替代外部session_manager依赖）。
    """
    action = params.get("action", "create")
    session_id = params.get("session_id", params.get("sid", ""))
    
    if action == "create":
        sid = session_id or f"sess_{int(time.time())}_{hash(params.get('scenario', '')) % 10000}"
        _session_store.sessions[sid] = {
            "session_id": sid,
            "created_at": datetime.now().isoformat() + "Z",
            "turn_count": 0,
            "context_window": [],
            "max_context_turns": 80,
            "customer_grade": "D",
            "urgency": "cold",
            "needs_detected": [],
            "intent_history": [],
            "compliance_flags": [],
            "products_discussed": [],
            "sop_day": 0,
            "total_ctas_sent": 0,
            "customer_profile": {},
            "priority_drift_detected": False
        }
        return {"result": {"action": "session_created", "session_id": sid, "status": "active", "context_window_size": 80}}
    
    elif action == "add_turn":
        if not session_id:
            return {"error": "session_id_required"}
        sess = _session_store.sessions.get(session_id)
        if not sess:
            return {"error": "session_not_found", "available_sessions": list(_session_store.sessions.keys())}
        
        turn_data = {
            "turn": sess["turn_count"] + 1,
            "role": params.get("role", "user"),
            "content": params.get("content", ""),
            "extracted_needs": params.get("extracted_needs", []),
            "grade_at_turn": params.get("grade"),
            "timestamp": datetime.now().isoformat() + "Z"
        }
        
        sess["turn_count"] += 1
        # Context window management (sliding window, max 80 turns)
        sess["context_window"].append(turn_data)
        if len(sess["context_window"]) > sess["max_context_turns"]:
            sess["context_window"] = sess["context_window"][-sess["max_context_turns"]:] 
        
        # Update grade if changed
        new_grade = params.get("grade", sess.get("customer_grade"))
        if new_grade and new_grade != sess["customer_grade"]:
            sess["customer_grade_evolution"] = sess.get("customer_grade_evolution", []) + [sess["customer_grade"]] + [new_grade]
        
        return {"result": {
            "action": "turn_added",
            "session_id": session_id,
            "turn_count": sess["turn_count"],
            "context_window_size": len(sess["context_window"]),
            "current_grade": new_grade
        }}
    
    elif action == "get_context":
        if not session_id:
            return {"error": "session_id_required"}
        sess = _session_store.sessions.get(session_id)
        if not sess:
            return {"error": "session_not_found"}
        return {"result": {
            "session_id": session_id,
            "turn_count": sess["turn_count"],
            "customer_grade": sess["customer_grade"],
            "urgency": sess["urgency"],
            "context_summary": [t for t in sess["context_window"][-10:]],  # Last 10 turns
            "compliance_flags_count": len(sess.get("compliance_flags", []))
        }}
    
    elif action == "summarize":
        if not session_id:
            return {"error": "session_id_required"}
        sess = _session_store.sessions.get(session_id)
        if not sess:
            return {"error": "session_not_found"}
        
        # Auto-generate summary
        needs_summary = list(set(n for t in sess["context_window"] for n in t.get("extracted_needs", [])))
        grade_history = sess.get("customer_grade_evolution", []) + [sess["customer_grade"]]
        
        return {"result": {
            "action": "summary_generated",
            "session_id": session_id,
            "total_turns": sess["turn_count"],
            "customer_grade_trajectory": grade_history[-3:],  # Last 3 grades
            "key_needs": needs_summary[:5],
            "estimated_conversion_score": min(100, len(needs_summary) * 20 + (30 if sess["customer_grade"] in ["A", "B"] else 0)),
            "next_recommended_action": "consultation_booking" if sess["customer_grade"] in ["A", "B"] and sess["turn_count"] >= 4 else "content_nurture"
        }}
    
    elif action == "list_sessions":
        return {"result": {
            "active_sessions": len(_session_store.sessions),
            "sessions": [{"id": k, "turns": v["turn_count"], "grade": v["customer_grade"], "created": v["created_at"]}
                         for k, v in _session_store.sessions.items()]
        }}
    
    elif action == "delete":
        if not session_id:
            return {"error": "session_id_required"}
        if session_id in _session_store.sessions:
            del _session_store.sessions[session_id]
            return {"result": {"action": "session_deleted", "session_id": session_id}}
        return {"error": "session_not_found"}
    
    return {"error": "invalid_action", "available_actions": ["create", "add_turn", "get_context", "summarize", "list_sessions", "delete"]}


# ============================================================
# R30 v2.0: 新增工具 10 - compliance_trend_analysis (合规趋势分析)
# ============================================================

def handle_compliance_trend_analysis(params: dict) -> dict:
    """Tool 10: 合规趋势分析 + 违规模式检测。
    分析历史合规检查结果，发现高频违规词/模式，生成改进报告。
    """
    action = params.get("action", "analyze")
    
    if action == "analyze":
        # Analyze stored compliance history
        history = _session_store.compliance_history[-50:]  # Last 50 checks
        
        if not history:
            return {"result": {
                "status": "no_history",
                "message": "尚无合规历史数据，请先使用compliance_check记录结果",
                "suggestion": "将compliance_check的结果session_id传入以关联分析"
            }}
        
        # Aggregate violations by rule_id
        violation_counts: Dict[str, int] = {}
        blocked_count = 0
        flagged_count = 0
        for entry in history:
            status = entry.get("status", "")
            if status == "BLOCKED":
                blocked_count += 1
            elif status == "FLAGGED":
                flagged_count += 1
            for v in entry.get("violations", []):
                rid = v.get("rule_id", "unknown")
                violation_counts[rid] = violation_counts.get(rid, 0) + 1
        
        # Sort by frequency
        top_violations = sorted(violation_counts.items(), key=lambda x: -x[1])[:5]
        
        # Risk level assessment
        total = len(history)
        violation_rate = (blocked_count + flagged_count) / max(total, 1)
        if violation_rate > 0.6:
            risk_level = "HIGH"
            recommendation = "立即审查所有待发布内容，建立合规预审流程"
        elif violation_rate > 0.3:
            risk_level = "MEDIUM"
            recommendation = "加强内容审核频次，重点关注高频违规规则"
        else:
            risk_level = "LOW"
            recommendation = "维持当前合规标准，定期抽检即可"
        
        # RL-011 strict mode coverage check
        strict_usage = sum(1 for e in history if e.get("strict_mode", False))
        
        return {
            "result": {
                "status": "analysis_complete",
                "total_checks": total,
                "violation_rate": round(violation_rate, 3),
                "blocked_count": blocked_count,
                "flagged_count": flagged_count,
                "risk_level": risk_level,
                "top_violations": [{"rule_id": r, "count": c} for r, c in top_violations],
                "compliance_trend": "improving" if blocked_count > flagged_count else "stable",
                "recommendation": recommendation,
                "strict_mode_coverage": round(strict_usage / max(total, 1), 3),
                "policy_update_needed": top_violations[:2] if any(c > 3 for _, c in top_violations) else []
            }
        }
    
    elif action == "record":
        # Record a compliance check result for trend analysis
        session_id = params.get("session_id")
        status = params.get("status", "PASS")
        violations = params.get("violations", [])
        strict_mode = params.get("strict_mode", False)
        
        _session_store.compliance_history.append({
            "session_id": session_id,
            "status": status,
            "violations": violations,
            "strict_mode": strict_mode,
            "timestamp": datetime.now().isoformat() + "Z"
        })
        
        return {"result": {"action": "recorded", "total_records": len(_session_store.compliance_history)}}
    
    elif action == "get_rule_stats":
        # Per-rule statistics
        stats = {}
        for rule in RED_LINE_RULES:
            rid = rule["rule_id"]
            hits = sum(1 for e in _session_store.compliance_history for v in e.get("violations", []) if v.get("rule_id") == rid)
            stats[rid] = {"rule_name": rule["name"], "severity": rule["severity"], "total_hits": hits}
        for rule in YELLOW_LINE_RULES:
            rid = rule["rule_id"]
            hits = sum(1 for e in _session_store.compliance_history for v in e.get("violations", []) if v.get("rule_id") == rid)
            stats[rid] = {"rule_name": rule["name"], "severity": "MEDIUM", "total_hits": hits}
        
        return {"result": {"rule_statistics": stats, "total_rules_monitored": len(RED_LINE_RULES) + len(YELLOW_LINE_RULES)}}
    
    return {"error": "invalid_action", "available_actions": ["analyze", "record", "get_rule_stats"]}
TOOL_HANDLERS = {
    "insurance_product_query": handle_insurance_product_query,
    "compliance_check": handle_compliance_check,
    "needs_assessment": handle_needs_assessment,
    "objection_handler": handle_objection_handler,
    "private_sop_runner": handle_private_sop_runner,
    # R30 v2.0新增工具
    "compliance_rewrite": handle_compliance_rewrite,
    "lifecycle_analyzer": handle_lifecycle_analyzer,
    "client_crm_tag": handle_client_crm_tag,
    "multi_turn_dialogue": handle_multi_turn_dialogue,
    "compliance_trend_analysis": handle_compliance_trend_analysis,
}


def main_stdio_loop():
    """stdio-based MCP server loop"""
    initialized = False
    
    for line in sys.stdin:
        try:
            msg_dict = json.loads(line.strip())
        except json.JSONDecodeError:
            continue

        # Initialize handshake
        if msg_dict.get("method") == "initialize":
            resp = JSONRPCMessage(id=msg_dict.get("id"), result=handle_initialize())
            sys.stdout.write(resp.to_json())
            sys.stdout.flush()
            initialized = True
            continue
        
        # Send initialized notification
        if msg_dict.get("method") == "notifications/initialized":
            continue

        # Tools/list request
        if msg_dict.get("method") == "tools/list":
            resp = JSONRPCMessage(id=msg_dict.get("id"), result=handle_tools_list())
            sys.stdout.write(resp.to_json())
            sys.stdout.flush()
            continue

        # Tool call request
        method = msg_dict.get("method", "")
        if method == "tools/call":
            # Accept both MCP spec format (params.name) and convenience format (top-level name)
            params_obj = msg_dict.get("params", {})
            tool_name = params_obj.get("name", msg_dict.get("name", ""))
            arguments = params_obj.get("arguments", msg_dict.get("arguments", {}))
            handler = TOOL_HANDLERS.get(tool_name)
            
            if not handler:
                resp = JSONRPCMessage(
                    id=msg_dict.get("id"),
                    error={"code": -32601, "message": f"Tool not found: {tool_name}"}
                )
                sys.stdout.write(resp.to_json())
                sys.stdout.flush()
                continue

            try:
                result = handler(arguments)
            except Exception as e:
                result = {"error": str(e)}

            resp = JSONRPCMessage(id=msg_dict.get("id"), result=result)
            sys.stdout.write(resp.to_json())
            sys.stdout.flush()
            continue


if __name__ == "__main__":
    main_stdio_loop()


