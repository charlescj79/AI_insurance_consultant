def load_objection_db():
    script_dir = os.path.dirname(os.path.abspath(__file__))
    parent_dir = os.path.dirname(script_dir)
    db_path = os.path.join(parent_dir, "cli", "objection-scripts-db.json")
    try:
        with open(db_path, "r", encoding="utf-8") as f:
            data = json.load(f)
        return data.get("objection_scripts", [])
    except FileNotFoundError:
        db_mcp = os.path.join(script_dir, "..", "cli", "objection-scripts-db.json")
        with open(db_mcp, "r", encoding="utf-8") as f:
            data = json.load(f)
        return data.get("objection_scripts", [])


def _fuzzy_match_objection(query_category: str, query_scenario: str, scripts: list) -> Optional[dict]:
    candidates = []
    for s in scripts:
        if query_category and s.get("category") != query_category:
            continue
        scene_score = 0
        if query_scenario:
            scenario_text = (s.get("scenario", "") + s.get("scenario_cn", "")).lower()
            q_lower = query_scenario.lower()
            if q_lower in scenario_text:
                scene_score += 10
            else:
                words = q_lower.split() if ' ' in q_lower else [q_lower]
                for word in words:
                    if len(word) >= 2 and word in scenario_text:
                        scene_score += 3
        else:
            scene_score = 1
        candidates.append((scene_score, s))
    if candidates:
        candidates.sort(key=lambda x: -x[0])
        return candidates[0][1]
    return None


