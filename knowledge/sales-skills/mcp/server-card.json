{
  "schemaVersion": "1.0.0",
  "name": "insurance-sales-mcp",
  "version": "1.3.0",
  "description": "Hong Kong Insurance Sales MCP Server \u2014 GL-44/GL34 compliance engine, 11 tools for insurance advisory automation with built-in regulatory red-line checks. [EU AI Act Art.50: users informed they interact with automated system]",
  "icon": "shield",
  "category": "Insurance & Finance",
  "author": {
    "name": "Insurance Tech Team",
    "email": "charlescj79@gmail.com"
  },
  "repository": {
    "url": "https://github.com/charlescj79/AI_insurance_consultant",
    "type": "git"
  },
  "transport": [
    "stdio",
    "streamable-http"
  ],
  "auth": {
    "method": "none",
    "notes": "No auth required for stdio mode. HTTP mode uses bearer token in Authorization header."
  },
  "configuration": {
    "mcpServers": {
      "insurance-sales-mcp": {
        "command": "python3",
        "args": [
          "/path/to/server.py"
        ],
        "env": {},
        "transport": "stdio"
      }
    },
    "docker": {
      "image": "ai-insurance-advisor/hk-insurance-mcp:1.3.0",
      "command": [
        "python3",
        "/app/server.py"
      ],
      "volumes": [
        "/data:/data"
      ]
    }
  },
  "tools": [
    {
      "name": "product_query",
      "description": "Query Hong Kong insurance product specifications and features",
      "annotations": {
        "title": "Product Query",
        "readOnlyHint": true,
        "destructiveHint": false,
        "idempotentHint": true,
        "openWorldHint": false
      }
    },
    {
      "name": "compliance_check",
      "description": "Check content against GL-44 red-line rules (14 rules) + yellow-line rules (4 rules)",
      "annotations": {
        "title": "GL-44 Compliance Check",
        "readOnlyHint": true,
        "destructiveHint": false,
        "idempotentHint": true,
        "openWorldHint": false
      }
    },
    {
      "name": "gl34_compliance_check",
      "description": "Check content against GL-34 compliance requirements",
      "annotations": {
        "title": "GL-34 Compliance Check",
        "readOnlyHint": true,
        "destructiveHint": false,
        "idempotentHint": true,
        "openWorldHint": false
      }
    },
    {
      "name": "needs_assessment",
      "description": "Multi-turn insurance needs analysis dialogue",
      "annotations": {
        "title": "Needs Assessment",
        "readOnlyHint": false,
        "destructiveHint": false,
        "idempotentHint": false,
        "openWorldHint": true
      }
    },
    {
      "name": "objection_handler",
      "description": "Handle client objections with compliant responses",
      "annotations": {
        "title": "Objection Handler",
        "readOnlyHint": false,
        "destructiveHint": false,
        "idempotentHint": false,
        "openWorldHint": true
      }
    },
    {
      "name": "private_sop_runner",
      "description": "Execute private SOP workflow for insurance consultation",
      "annotations": {
        "title": "Private SOP Runner",
        "readOnlyHint": false,
        "destructiveHint": false,
        "idempotentHint": false,
        "openWorldHint": true
      }
    },
    {
      "name": "compliance_rewrite",
      "description": "Rewrite non-compliant content to meet GL-44 requirements",
      "annotations": {
        "title": "Compliance Rewrite",
        "readOnlyHint": false,
        "destructiveHint": false,
        "idempotentHint": false,
        "openWorldHint": true
      }
    },
    {
      "name": "lifecycle_analyzer",
      "description": "Analyze client lifecycle stage and recommend next actions",
      "annotations": {
        "title": "Lifecycle Analyzer",
        "readOnlyHint": true,
        "destructiveHint": false,
        "idempotentHint": true,
        "openWorldHint": false
      }
    },
    {
      "name": "client_crm_tag",
      "description": "Manage CRM tags for client segmentation",
      "annotations": {
        "title": "CRM Tag Manager",
        "readOnlyHint": false,
        "destructiveHint": false,
        "idempotentHint": false,
        "openWorldHint": true
      }
    },
    {
      "name": "multi_turn_dialogue",
      "description": "Stateful multi-turn insurance consultation dialogue",
      "annotations": {
        "title": "Multi-Turn Dialogue",
        "readOnlyHint": false,
        "destructiveHint": false,
        "idempotentHint": false,
        "openWorldHint": true
      }
    },
    {
      "name": "compliance_trend_analysis",
      "description": "Analyze compliance trends across consultation history",
      "annotations": {
        "title": "Compliance Trend Analysis",
        "readOnlyHint": true,
        "destructiveHint": false,
        "idempotentHint": true,
        "openWorldHint": false
      }
    }
  ],
  "capabilities": {
    "gl44_compliance": true,
    "gl34_compliance": true,
    "red_line_checks": 14,
    "yellow_line_checks": 4,
    "private_deployment": true
  },
  "links": {
    "homepage": "https://github.com/charlescj79/AI_insurance_consultant",
    "privacy": "https://github.com/charlescj79/AI_insurance_consultant/blob/main/docs/PRIVACY_POLICY.md",
    "license": "Apache-2.0"
  },
  "documentation": {
    "code": "https://github.com/charlescj79/AI_insurance_consultant/blob/main/README.md",
    "faq": "https://github.com/ai-insurance-advisor/hk-insurance-mcp-server/blob/main/docs/FAQ.md",
    "support": "https://github.com/charlescj79/AI_insurance_consultant/issues",
    "screenshots": []
  },
  "pricing": {
    "type": "free",
    "description": "Free open-source insurance sales MCP server, Apache-2.0 license"
  },
  "keywords": [
    "insurance",
    "hong-kong-insurance",
    "compliance",
    "GL-44",
    "GL34",
    "sales",
    "crm",
    "agent",
    "financial-advisor",
    "eu-ai-act",
    "art50"
  ],
  "tags": [
    "insurance",
    "compliance",
    "sales",
    "crm",
    "finserve"
  ],
  "license": "Apache-2.0",
  "requirements": {
    "python": ">=3.9",
    "packages": [
      "httpx>=0.27",
      "rich>=13.0"
    ]
  }
}
